{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/next",
      "config": {
        "distDir": ".next"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/backend/$1"
    },
    {
      "src": "/projects/(.*)",
      "dest": "/backend/projects/$1"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
