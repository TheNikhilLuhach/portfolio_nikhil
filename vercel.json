{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/backend/$1"
    },
    {
      "src": "/projects/(.*)",
      "dest": "/backend/projects/$1"
    }
  ],
  "functions": {
    "api/projects.js": {
      "maxDuration": 10
    },
    "api/skills.js": {
      "maxDuration": 10
    },
    "api/experience.js": {
      "maxDuration": 10
    },
    "api/projects/[...path].js": {
      "maxDuration": 10
    }
  },
  "env": {
    "NODE_ENV": "production"
  },
  "framework": "nextjs"
}
